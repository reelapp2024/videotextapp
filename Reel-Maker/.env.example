# Production / Live app: set to your backend URL so TTS and other API features work.
# Example: VITE_API_URL=https://your-backend.railway.app
# Example: VITE_API_URL=https://video-text-app-backend.vercel.app

# Milestone 3: enable shared render-core text path (preview only; default off)
# VITE_RENDER_CORE_TEXT=1

# Milestone 4: animation engine via render-core (default on; set 0 to disable telemetry scope)
# VITE_RENDER_CORE_ANIMATION=1
